{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/schemas/governed-object.schema.json",
  "title": "Governed Object Declaration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "display_name",
    "source_root"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+([._-][a-z0-9]+)*$",
      "description": "Stable repo-declared identity."
    },
    "kind": {
      "type": "string",
      "enum": [
        "skill",
        "plugin"
      ]
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "source_root": {
      "type": "string",
      "minLength": 1,
      "description": "Path root used for content-hash versioning."
    },
    "owner": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
